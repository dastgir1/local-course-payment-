{{#coursedata}}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card" >
                <div class="row">
                    <div class="col-md-4">
                        <img class="w-100" src="{{courseimageurl}}"  height="200px" alt="Card image cap">
                    </div>
                    <div class=" col-md-8">
                        <h5 class="">{{coursename}}</h5>
                        {{{coursesummary}}}
                        <p>{{#str}}courseprice,local_course_carousel{{/str}}{{courseprice}} {{currency}}</p>

                        <a href="{{signuplink}}" class="btn btn-primary">{{#str}}paynow,local_course_carousel{{/str}}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{/coursedata}}